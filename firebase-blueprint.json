{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "timestamp": { "type": "number" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "kitchenStatus": { "type": "string" },
        "customerId": { "type": "string" },
        "pointsEarned": { "type": "number" },
        "pointsRedeemed": { "type": "number" },
        "donationMessage": { "type": "string" }
      },
      "required": ["id", "orderNumber", "timestamp", "total", "status"]
    },
    "User": {
      "title": "User",
      "description": "A staff user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "stock": { "type": "number" },
        "barcode": { "type": "string" },
        "comboItems": { "type": "array" },
        "pointsPrice": { "type": "number" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "number" },
        "registeredBy": { "type": "string" },
        "category": { "type": "string" },
        "receiptUrl": { "type": "string" }
      },
      "required": ["id", "description", "amount", "timestamp"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "A student contribution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "monthReference": { "type": "string" },
        "paymentDate": { "type": "number" },
        "registeredBy": { "type": "string" }
      },
      "required": ["id", "studentName", "amount", "paymentDate"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A loyalty customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "points": { "type": "number" },
        "created_at": { "type": "number" },
        "prizes": { "type": "array" }
      },
      "required": ["id", "phone"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appName": { "type": "string" },
        "schoolClass": { "type": "string" },
        "mascotUrl": { "type": "string" },
        "schoolLogoUrl": { "type": "string" },
        "emptyCartImageUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "buttonSize": { "type": "string" },
        "customerLayout": { "type": "array" },
        "customerHeroUrl": { "type": "string" },
        "customerWelcomeTitle": { "type": "string" },
        "marqueeText": { "type": "string" }
      },
      "required": ["id"]
    }
  },
  "firestore": {
    "transactions": {
      "schema": "Transaction",
      "description": "All sales transactions"
    },
    "users": {
      "schema": "User",
      "description": "Staff users"
    },
    "products": {
      "schema": "Product",
      "description": "Products catalog"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Expenses"
    },
    "contributions": {
      "schema": "Contribution",
      "description": "Student contributions"
    },
    "customers": {
      "schema": "Customer",
      "description": "Loyalty customers"
    },
    "settings": {
      "schema": "Settings",
      "description": "Global settings"
    }
  }
}